NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/studyconnect
CLIENT_URL=http://localhost:5173

# Comma-separated, lower-case college domains.
APPROVED_EMAIL_DOMAINS=college.edu,students.college.edu

# Generate separate random values of at least 32 characters for production.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12

COOKIE_SECURE=false
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
LOG_LEVEL=dev
